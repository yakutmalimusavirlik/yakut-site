<!doctype html>
<html lang="tr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>Yakut Mali Müşavirlik | Dijital Kartvizit</title>
<meta name="description" content="Muhammet Lütfi Yakut - Serbest Muhasebeci Mali Müşavir dijital kartvizit ve iletişim bilgileri.">
<meta name="theme-color" content="#111111">
<meta property="og:title" content="Yakut Mali Müşavirlik">
<meta property="og:description" content="Muhammet Lütfi Yakut - Serbest Muhasebeci Mali Müşavir">
<meta property="og:type" content="website">
<link rel="manifest" href="./manifest.webmanifest">
<link rel="icon" href="./assets/icon-32.png">
<link rel="apple-touch-icon" href="./assets/icon-180.png">
<style>
:root {
  --bg:#f7f6f3; --paper:#fffdfa; --ink:#151515; --muted:#6d6962;
  --hair:#e7e1d8; --ruby:#b10f18; --ruby2:#d31d27;
  --shadow:0 30px 90px rgba(17,17,17,.12); --soft:0 12px 40px rgba(17,17,17,.07);
}
*{box-sizing:border-box}
body{
  margin:0; min-height:100vh; color:var(--ink);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Inter,Arial,sans-serif;
  background:
    radial-gradient(circle at 50% -10%, rgba(177,15,24,.12), transparent 34rem),
    linear-gradient(135deg, rgba(255,255,255,.92), rgba(247,246,243,.92)),
    var(--bg);
}
body:before{
  content:""; position:fixed; inset:0; pointer-events:none; opacity:.55;
  background:
    linear-gradient(115deg, transparent 0 28%, rgba(0,0,0,.035) 28.1% 28.3%, transparent 28.4% 100%),
    linear-gradient(245deg, transparent 0 61%, rgba(177,15,24,.045) 61.1% 61.25%, transparent 61.35% 100%);
}
.wrap{width:min(980px,calc(100% - 28px)); margin:0 auto; position:relative}
.shell{min-height:100svh; display:grid; place-items:center; padding:34px 0}
.card{
  width:min(760px,100%); border:1px solid rgba(231,225,216,.9);
  background:linear-gradient(180deg,rgba(255,253,250,.94),rgba(255,255,255,.84));
  border-radius:34px; box-shadow:var(--shadow); overflow:hidden; backdrop-filter:blur(20px);
}
.hero{padding:40px clamp(20px,5vw,54px) 30px; text-align:center; position:relative}
.hero:after{content:""; display:block; height:1px; background:linear-gradient(90deg,transparent,var(--hair),transparent); margin-top:30px}
.logo{display:block; width:min(410px,88%); margin:0 auto 24px; height:auto}
.name{font-size:clamp(34px,6vw,56px); letter-spacing:-.055em; line-height:.96; margin:0 0 10px; font-weight:850}
.title{margin:0; color:var(--muted); font-size:clamp(16px,2.5vw,20px)}
.loc{margin:22px auto 0; display:inline-flex; align-items:center; gap:10px; font-weight:700; color:#292724; padding:11px 16px; border:1px solid var(--hair); border-radius:18px; background:rgba(255,255,255,.62); line-height:1.35}
.list{padding:0 clamp(16px,5vw,44px) 28px}
.action{
  display:grid; grid-template-columns:auto 1fr auto; align-items:center; gap:16px;
  min-height:72px; padding:0 20px; color:var(--ink); text-decoration:none;
  border-bottom:1px solid var(--hair); transition:.18s ease;
}
.action:hover{background:rgba(177,15,24,.035)}
.ico{width:42px;height:42px;border-radius:14px;display:grid;place-items:center;color:var(--ruby);background:rgba(177,15,24,.075);font-size:21px}
.action strong{display:block;font-size:18px;letter-spacing:-.01em}
.action small{display:block;color:var(--muted);margin-top:4px;font-size:14px;line-height:1.25}
.chev{color:#8a847c;font-size:24px}
.tools{display:grid; grid-template-columns:1fr 1fr; gap:14px; padding:0 clamp(16px,5vw,44px) 40px}
.tool{
  min-height:96px; border:1px solid var(--hair); border-radius:22px; background:rgba(255,255,255,.62);
  display:flex; align-items:center; gap:14px; padding:18px; text-decoration:none; color:var(--ink); box-shadow:var(--soft);
}
.statement{text-align:center; padding:0 22px 38px; color:var(--muted)}
.mark{display:flex; align-items:center; justify-content:center; gap:18px; margin-bottom:16px}
.mark:before,.mark:after{content:""; width:82px; height:1px; background:linear-gradient(90deg,transparent,var(--ruby))}
.mark:after{background:linear-gradient(90deg,var(--ruby),transparent)}
.ruby{color:var(--ruby); font-size:18px}
.principles{font-weight:800; color:var(--ink); letter-spacing:.16em; text-transform:uppercase; font-size:13px}
.note{margin:10px auto 0; max-width:520px; line-height:1.55; font-size:14px}
.footer{padding:24px; text-align:center; color:#8a847c; font-size:13px; border-top:1px solid var(--hair); background:rgba(247,246,243,.52)}
@media(max-width:560px){
  .shell{padding:14px 0}
  .card{border-radius:26px}
  .hero{padding-top:28px}
  .logo{width:min(340px,92%)}
  .action{min-height:68px; padding:0 14px; gap:12px}
  .action strong{font-size:16px}
  .tools{grid-template-columns:1fr; padding-bottom:28px}
}
@media(prefers-reduced-motion:no-preference){
  .card{animation:rise .65s cubic-bezier(.2,.8,.2,1) both}
  @keyframes rise{from{opacity:0; transform:translateY(18px) scale(.985)}to{opacity:1; transform:none}}
}
</style>
</head>
<body>
<main class="shell">
  <div class="wrap">
    <section class="card" aria-label="Yakut Mali Müşavirlik dijital kartvizit">
      <div class="hero">
        <img class="logo" src="./assets/yakut-logo.png" alt="Yakut Mali Müşavirlik">
        <h1 class="name">Muhammet Lütfi Yakut</h1>
        <p class="title">Serbest Muhasebeci Mali Müşavir</p>
        <div class="loc">📍 Sarıgazi Mah. Atatürk Cad. No:38 İç Kapı No:5<br>Sancaktepe / İstanbul</div>
      </div>
      <div class="list">
        <a class="action" href="tel:+905423458001"><span class="ico">☎</span><span><strong>Telefon ile Ara</strong><small>0542 345 80 01</small></span><span class="chev">›</span></a>
        <a class="action" href="https://wa.me/905423458001?text=Merhaba%2C%20dijital%20kartvizitiniz%20%C3%BCzerinden%20ula%C5%9F%C4%B1yorum." target="_blank" rel="noopener"><span class="ico">●</span><span><strong>WhatsApp</strong><small>0542 345 80 01</small></span><span class="chev">›</span></a>
        <a class="action" href="mailto:yakutmalimusavirlik@gmail.com"><span class="ico">✉</span><span><strong>E-posta Gönder</strong><small>yakutmalimusavirlik@gmail.com</small></span><span class="chev">›</span></a>
        <a class="action" href="https://www.google.com/maps/place/41%C2%B000'29.6%22N+29%C2%B012'20.1%22E/@41.00828,29.2052462,20.5z/data=!4m4!3m3!8m2!3d41.0082321!4d29.2055912?hl=tr&entry=ttu&g_ep=EgoyMDI2MDYyOS4wIKXMDSoASAFQAw%3D%3D" target="_blank" rel="noopener"><span class="ico">⌖</span><span><strong>Haritada Aç</strong><small>Google Haritalar konumu</small></span><span class="chev">›</span></a>
      </div>
      <div class="tools">
        <a class="tool" href="./muhammet-lutfi-yakut.vcf"><span class="ico">♙</span><span><strong>Rehbere Kaydet</strong><small>VCF kişi kartı</small></span></a>
        <a class="tool" href="./assets/qr.png" target="_blank"><span class="ico">▦</span><span><strong>QR Kodu Aç</strong><small>Dijital kartvizit bağlantısı</small></span></a>
      </div>
      <div class="statement">
        <div class="mark"><span class="ruby">◆</span></div>
        <div class="principles">Güvenilir · Düzenli · Gizliliğe Özenli</div>
        <p class="note">Mesleki etik ve gizlilik ilkeleri gözetilerek mali müşavirlik hizmetleri sunulmaktadır.</p>
      </div>
      <footer class="footer">© 2026 Yakut Mali Müşavirlik · İstanbul</footer>
    </section>
  </div>
</main>
</body>
</html>
